-- Tính vị trí minimize từ click
local function computeClickPosition(input)
	local absX, absY = 0, 0
	if input then
		absX = input.Position.X
		absY = input.Position.Y
	else
		local absPos = Container.AbsolutePosition
		absX = absPos.X
		absY = absPos.Y
	end

	local halfMinW = minimizedSize.X.Offset / 2
	local halfMinH = minimizedSize.Y.Offset / 2

	local newAbsX = absX - halfMinW
	local newAbsY = absY - halfMinH

	local viewportSize = workspace.CurrentCamera.ViewportSize
	newAbsX = math.clamp(newAbsX, 0, viewportSize.X - minimizedSize.X.Offset)
	newAbsY = math.clamp(newAbsY, 0, viewportSize.Y - minimizedSize.Y.Offset)

	return UDim2.new(0, newAbsX, 0, newAbsY)
end

local minimized = false
local oldPosition = Container.Position
local tween

local function toggleMinimize(input)
	if tween then
		tween:Cancel()
	end

	minimized = not minimized

	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	if minimized then
		oldPosition = Container.Position
		local targetPosition = computeClickPosition(input)
		local targetCorner = UDim.new(0, 4)

		tween = TweenService:Create(Container, tweenInfo, {
			Size = minimizedSize,
			Position = targetPosition,
		})
		tween:Play()

		TweenService:Create(Corner, tweenInfo, {
			CornerRadius = targetCorner
		}):Play()

		TweenService:Create(Stroke, tweenInfo, {
			Thickness = 1
		}):Play()

		task.delay(0.05, function()
			if minimized then
				Content.Visible = false
				Content.Size = UDim2.new(1, 0, 0, 0)
			end
		end)
	else
		Content.Visible = true

		tween = TweenService:Create(Container, tweenInfo, {
			Size = containerSize,
			Position = oldPosition,
		})
		tween:Play()

		TweenService:Create(Corner, tweenInfo, {
			CornerRadius = UDim.new(0, 12)
		}):Play()

		TweenService:Create(Stroke, tweenInfo, {
			Thickness = 1
		}):Play()

		Content.Size = UDim2.new(1, 0, 1, -46)
	end
end

Icon.MouseButton1Click:Connect(function(input)
