-- Biến thời gian riêng để tránh os.clock() bị reset
local elapsedTime = 0
local glowConnection

local function startGlowEffect()
	glowConnection = RunService.Heartbeat:Connect(function(dt)
		if minimized then return end

		-- Tích lũy thời gian thực
		elapsedTime = elapsedTime + dt

		local t = elapsedTime
		
		-- Đổi màu chữ chính: Xanh (0.55) → Trắng (sat=0) → Xanh (0.55)
		local hue = 0.55  -- Xanh dương cố định
		local sat = 0.5 + math.sin(t * 0.8) * 0.5  -- 0.0 → 1.0 → 0.0
		
		ClientName.TextColor3 = Color3.fromHSV(hue, sat, 1.0)

		-- Di chuyển bóng sang trái phải
		local offsetX = math.sin(t * 2.5) * 3
		ClientShadow.Position = UDim2.new(0, 40 + offsetX, 0, 8 + math.sin(t * 2.5) * 0.5)

		-- Đổi màu bóng theo chữ
		local shadowSat = math.clamp(sat - 0.2, 0, 1)
		ClientShadow.TextColor3 = Color3.fromHSV(hue, shadowSat, 0.8)

		-- Nhấp nháy transparency nhẹ
		ClientShadow.TextTransparency = 0.3 + math.sin(t * 3) * 0.15
	end)
end

